require "shellwords"

default_platform(:ios)

APP_ID = "com.orjinalp.yazitura"
TEAM_ID = "2CTYTPF2MA"

platform :ios do
  desc "Derle, imzala ve App Store Connect'e (TestFlight işleme) yükle"
  lane :release do
    # CI için geçici keychain oluşturur (sertifikaların kurulacağı yer)
    setup_ci

    # App Store Connect API anahtarı — Mac/parola/2FA gerektirmez.
    # Anahtar dosyası workflow'un "API anahtarını hazırla" adımında yazılır.
    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("ASC_KEY_ID"),
      issuer_id: ENV.fetch("ASC_ISSUER_ID"),
      key_filepath: ENV.fetch("ASC_KEY_PATH"),
      in_house: false
    )

    build_number = ENV["BUILD_NUMBER"] || "1"

    # Xcode bulut (otomatik) imzalaması: sertifika + provisioning profile Apple
    # tarafında API anahtarıyla üretilir/indirilir; runner'da cert/keychain derdi yok.
    build_app(
      project: "YaziTura.xcodeproj",
      scheme: "YaziTura",
      configuration: "Release",
      export_method: "app-store",
      output_directory: "build",
      output_name: "YaziTura.ipa",
      xcargs: [
        "-allowProvisioningUpdates",
        "-authenticationKeyID", ENV.fetch("ASC_KEY_ID"),
        "-authenticationKeyIssuerID", ENV.fetch("ASC_ISSUER_ID"),
        "-authenticationKeyPath", ENV.fetch("ASC_KEY_PATH"),
        "DEVELOPMENT_TEAM=#{TEAM_ID}",
        "CODE_SIGN_STYLE=Automatic",
        "CURRENT_PROJECT_VERSION=#{build_number}"
      ].shelljoin,
      export_options: {
        signingStyle: "automatic",
        teamID: TEAM_ID
      }
    )

    # Binary'yi App Store Connect'e yükle (TestFlight'ta işlenir).
    # Listeleme/gönderim tarayıcıdan tamamlanır.
    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end
end
